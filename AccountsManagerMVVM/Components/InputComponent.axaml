<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AccountsManagerMVVM.Components.InputComponent"
             x:Name="Component">
    <UserControl.Styles>
        <StyleInclude Source="../../Styles/Styles.axaml" />
    </UserControl.Styles>

    <Grid ColumnDefinitions="*, 2.5*">
        <Label Content="{Binding ElementName=Component, Path=Label, Mode=OneWay}"
               Target="{Binding ElementName=Input}"
               Grid.Column="0" />
        <TextBox x:Name="Input"
                 PlaceholderText="{Binding ElementName=Component, Path=Placeholder, Mode=OneWay}"
                 Text="{Binding ElementName=Component, Path=Value, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                 Grid.Column="1" />
    </Grid>
</UserControl>
