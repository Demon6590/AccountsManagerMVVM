<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AccountsManagerMVVM.App"
             xmlns:local="using:AccountsManagerMVVM"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://AccountsManagerMVVM/Styles/Styles.axaml" />
    </Application.Styles>
    <Application.Resources>
        <ResourceDictionary>
                 <x:String x:Key="Title">Менеджер аккаунтов</x:String>           
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://AccountsManagerMVVM/Templates/ButtonBaseTemplate.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>

        
    </Application.Resources>
</Application>