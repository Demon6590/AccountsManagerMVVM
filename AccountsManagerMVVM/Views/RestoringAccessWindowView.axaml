<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AccountsManagerMVVM.ViewModels"
             xmlns:c="using:AccountsManagerMVVM.Components"
             x:DataType="vm:RegistrationWindowViewModel"
             x:Class="AccountsManagerMVVM.Views.RestoringAccessWindowView">
        
    <StackPanel Orientation="Vertical">
        <Panel Classes="center">
            <TextBlock Text="Восстановление доступа"
                       Classes="title" />
        </Panel>
        <StackPanel Orientation="Vertical">
            <c:InputComponentMail Placeholder="Введите почту"
                                  Label="Электронная почта"
                                  Value="{Binding Email, Mode=TwoWay}"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    Classes="center">
            <Button Content="Восстановить пароль"
                    Classes="login"
                    Template="{StaticResource ResourceKey=ButtonLeftTemplate}" />
            <Button Content="Назад"
                    Classes="cancel"
                    Template="{StaticResource ResourceKey=ButtonRightTemplate}"/>
        </StackPanel>
    </StackPanel>
</UserControl>
