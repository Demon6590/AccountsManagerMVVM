<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:AccountsManagerMVVM.Components"
             x:Class="AccountsManagerMVVM.Views.AuthWindowView">
    <StackPanel Orientation="Vertical">
        <Panel>
            <TextBlock Text="Авторизация" />
        </Panel>
        <StackPanel>
            <components:InputComponentMail Placeholder="ведите логин" Label="Логин" />
            <components:InputComponentPassword Placeholder="ведите пароль" Label="пароль"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Button Content="Войти" Classes="Flat"/>
            <Button Content="Отмена" Classes="Flat"/>
        </StackPanel>
        <StackPanel>
            <HyperlinkButton Content="Зарегистрироваться"/>
            
            <HyperlinkButton Content="Забыл пароль?"/>
        </StackPanel>
    </StackPanel>
</UserControl>
