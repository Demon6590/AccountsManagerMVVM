<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="using:AccountsManagerMVVM.Components"
             x:Class="AccountsManagerMVVM.Views.AuthWindowView">
    <StackPanel Orientation="Vertical">
        <Panel Classes="center">
            <TextBlock Text="Авторизация" Classes="title"/>
        </Panel>
        <StackPanel>
            <c:InputComponentMail Placeholder="ведите логин" Label="Логин" />
            
            <c:InputComponentPassword Placeholder="ведите пароль" Label="Пароль"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Classes="cancel">
            <Button Content="Войти" Classes="login" Template="{StaticResource ResourceKey=ButtonLeftTemplate}"/>
            <Button Content="Отмена" Classes="cancel" Template="{StaticResource ResourceKey=ButtonRightTemplate}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Classes="cancel">
            <HyperlinkButton Content="Зарегистрироваться"/>
            
            <HyperlinkButton Content="Забыл пароль?"/>
        </StackPanel>
    </StackPanel>
</UserControl>
